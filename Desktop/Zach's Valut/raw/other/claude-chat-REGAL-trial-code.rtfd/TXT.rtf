    cure_frac\cf18 \strokec18 ,\cf15 \strokec15  median_os\cf18 \strokec18 ,\cf15 \strokec15  shape = params\
    s = mixture_cure_survival\cf18 \strokec18 (\cf15 \strokec15 t_obs\cf18 \strokec18 ,\cf15 \strokec15  cure_frac\cf18 \strokec18 ,\cf15 \strokec15  median_os\cf18 \strokec18 ,\cf15 \strokec15  shape\cf18 \strokec18 )\cf15 \strokec15 \
